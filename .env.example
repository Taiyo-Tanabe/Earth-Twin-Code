# ── Required ──────────────────────────────────────────────
# Anthropic API key for AI Data Scout (Claude Haiku)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: ACLED armed conflict data ───────────────────
# Requires Research Access approval at https://acleddata.com/
# Without this, the pipeline falls back to UCDP GED data.
ACLED_EMAIL=
ACLED_PASSWORD=

# ── Infrastructure (defaults work for local Docker) ───────
MINIO_ROOT_USER=earthtwin
MINIO_ROOT_PASSWORD=earthtwin123
POSTGRES_USER=earthtwin
POSTGRES_PASSWORD=earthtwin123
POSTGRES_DB=earthtwin
AIRFLOW_ADMIN_PASSWORD=admin
